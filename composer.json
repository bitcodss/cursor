{
    "name": "personal/portfolio-tracker",
    "description": "Personal Stock/ETF Portfolio Tracking Application",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "monolog/monolog": "^2.8",
        "vlucas/phpdotenv": "^5.5",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "PortfolioTracker\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"copy('.env.example', '.env');\""
        ]
    }
}